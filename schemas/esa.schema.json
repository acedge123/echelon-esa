{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://esa-spec.org/schemas/esa-v0.2.json",
  "title": "Economic Service Architecture Manifest",
  "type": "object",
  "required": ["spec_version", "service", "capabilities"],
  "additionalProperties": false,
  "properties": {
    "spec_version": { "const": "0.2" },
    "service": {
      "type": "object",
      "required": ["id", "name", "description", "version", "owner", "status", "terms_url", "support_url"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 3 },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "version": { "$ref": "#/$defs/semver" },
        "owner": { "type": "string", "minLength": 1 },
        "base_url": { "type": "string", "format": "uri" },
        "status": { "$ref": "#/$defs/status" },
        "terms_url": { "type": "string", "format": "uri" },
        "privacy_url": { "type": "string", "format": "uri" },
        "support_url": { "type": "string", "format": "uri" },
        "security_url": { "type": "string", "format": "uri" }
      }
    },
    "schemas": {
      "type": "object",
      "additionalProperties": { "type": "string", "format": "uri" }
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/capability" }
    },
    "discovery": { "type": "object" },
    "governance": { "type": "object" }
  },
  "$defs": {
    "semver": { "type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$" },
    "status": { "enum": ["experimental", "beta", "stable", "deprecated", "sunset"] },
    "period": { "enum": ["second", "minute", "hour", "day", "week", "month", "year"] },
    "money": { "type": "string", "pattern": "^[0-9]+(?:\\.[0-9]+)?$" },
    "authMethod": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": { "enum": ["public", "session", "api_key", "oauth2", "signed_service"] },
        "issuers": { "type": "array", "items": { "type": "string", "format": "uri" } },
        "scopes": { "type": "array", "items": { "type": "string" } }
      }
    },
    "paymentMethod": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "enum": ["x402", "invoice", "subscription_entitlement", "credits", "contract"] },
        "network": { "type": "string" },
        "currency": { "type": "string" },
        "pay_to": { "type": "string" },
        "verifier_url": { "type": "string", "format": "uri" }
      },
      "additionalProperties": true
    },
    "pricing": {
      "oneOf": [
        { "type": "object", "required": ["model"], "properties": { "model": { "const": "free" } }, "additionalProperties": false },
        { "type": "object", "required": ["model", "amount", "currency"], "properties": { "model": { "const": "per_request" }, "amount": { "$ref": "#/$defs/money" }, "currency": { "type": "string" } }, "additionalProperties": false },
        { "type": "object", "required": ["model", "unit", "currency", "rates"], "properties": { "model": { "const": "metered" }, "unit": { "type": "string" }, "currency": { "type": "string" }, "rates": { "type": "array", "minItems": 1, "items": { "type": "object", "required": ["from", "amount"], "properties": { "from": { "type": "number" }, "amount": { "$ref": "#/$defs/money" } }, "additionalProperties": false } } }, "additionalProperties": false },
        { "type": "object", "required": ["model", "unit", "currency", "tiers"], "properties": { "model": { "const": "tiered" }, "unit": { "type": "string" }, "currency": { "type": "string" }, "tiers": { "type": "array", "minItems": 1, "items": { "type": "object", "required": ["amount"], "properties": { "from": { "type": "number" }, "up_to": { "type": "number" }, "amount": { "$ref": "#/$defs/money" } }, "additionalProperties": false } } }, "additionalProperties": false },
        { "type": "object", "required": ["model", "plans"], "properties": { "model": { "const": "subscription" }, "plans": { "type": "array", "minItems": 1, "items": { "type": "object", "required": ["id", "amount", "currency", "billing_period"], "properties": { "id": { "type": "string" }, "amount": { "$ref": "#/$defs/money" }, "currency": { "type": "string" }, "billing_period": { "$ref": "#/$defs/period" }, "included_usage": { "type": "number" }, "overage_amount": { "$ref": "#/$defs/money" }, "overage_unit": { "type": "string" } }, "additionalProperties": false } } }, "additionalProperties": false },
        { "type": "object", "required": ["model", "credit_unit", "credits_per_unit"], "properties": { "model": { "const": "credits" }, "credit_unit": { "type": "string" }, "credits_per_unit": { "$ref": "#/$defs/money" } }, "additionalProperties": false },
        { "type": "object", "required": ["model"], "properties": { "model": { "const": "contract" }, "terms_url": { "type": "string", "format": "uri" }, "contact_url": { "type": "string", "format": "uri" } }, "anyOf": [{ "required": ["terms_url"] }, { "required": ["contact_url"] }], "additionalProperties": false },
        { "type": "object", "required": ["model", "basis", "percentage", "settlement_period"], "properties": { "model": { "const": "revenue_share" }, "basis": { "type": "string" }, "percentage": { "$ref": "#/$defs/money" }, "settlement_period": { "$ref": "#/$defs/period" } }, "additionalProperties": false },
        { "type": "object", "required": ["model", "components"], "properties": { "model": { "const": "hybrid" }, "components": { "type": "array", "minItems": 2, "items": { "type": "object" } } }, "additionalProperties": false }
      ]
    },
    "capability": {
      "type": "object",
      "required": ["id", "version", "name", "description", "status", "interfaces", "input_schema", "output_schema", "auth", "payments", "pricing", "rate_limits", "sla", "data", "idempotency", "async", "errors", "events", "deprecation"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)+$" },
        "version": { "$ref": "#/$defs/semver" },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "status": { "$ref": "#/$defs/status" },
        "interfaces": { "type": "object", "minProperties": 1 },
        "input_schema": { "type": "string", "format": "uri" },
        "output_schema": { "type": "string", "format": "uri" },
        "auth": { "type": "object", "required": ["methods"], "properties": { "methods": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/authMethod" } } }, "additionalProperties": false },
        "payments": { "type": "object", "required": ["methods"], "properties": { "methods": { "type": "array", "items": { "$ref": "#/$defs/paymentMethod" } } }, "additionalProperties": false },
        "pricing": { "$ref": "#/$defs/pricing" },
        "rate_limits": { "type": "object" },
        "sla": { "type": "object" },
        "data": { "type": "object", "required": ["classification", "pii", "retention", "freshness"], "properties": { "classification": { "type": "string" }, "pii": { "type": "object", "required": ["request", "response"], "properties": { "request": { "type": "boolean" }, "response": { "type": "boolean" } }, "additionalProperties": false }, "retention": { "type": "string" }, "freshness": { "type": "string" }, "permitted_uses": { "type": "array", "items": { "type": "string" } }, "redistribution": { "type": "string" } }, "additionalProperties": true },
        "idempotency": { "type": "object", "required": ["supported"], "properties": { "supported": { "type": "boolean" }, "header": { "type": "string" }, "retention_hours": { "type": "integer", "minimum": 1 } }, "additionalProperties": false },
        "async": { "type": "object", "required": ["supported"], "properties": { "supported": { "type": "boolean" }, "mode": { "enum": ["polling", "callback", "webhook", "queue", "event"] }, "status_url_template": { "type": "string" }, "result_schema": { "type": "string", "format": "uri" }, "webhook": { "type": "object" } }, "additionalProperties": true },
        "errors": { "type": "array", "items": { "type": "object", "required": ["code", "protocol_status", "retryable"], "properties": { "code": { "type": "string" }, "protocol_status": { "type": "integer" }, "retryable": { "type": "boolean" }, "docs_url": { "type": "string", "format": "uri" } }, "additionalProperties": false } },
        "events": { "type": "array", "items": { "type": "object" } },
        "deprecation": { "type": "object", "required": ["deprecated_on", "sunset_on", "successor_capability_id"], "properties": { "deprecated_on": { "type": ["string", "null"], "format": "date" }, "sunset_on": { "type": ["string", "null"], "format": "date" }, "successor_capability_id": { "type": ["string", "null"] }, "successor_version": { "type": ["string", "null"] } }, "additionalProperties": false }
      }
    }
  }
}