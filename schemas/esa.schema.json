{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://esa-spec.org/schemas/esa-v0.2.json",
  "title": "Economic Service Architecture Manifest",
  "type": "object",
  "required": ["spec_version", "service", "capabilities"],
  "additionalProperties": false,
  "properties": {
    "spec_version": { "type": "string", "const": "0.2" },
    "service": {
      "type": "object",
      "required": ["id", "name", "version", "owner", "status"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+" },
        "owner": { "type": "string", "minLength": 1 },
        "base_url": { "type": "string", "format": "uri" },
        "status": { "enum": ["experimental", "beta", "stable", "deprecated", "sunset"] },
        "terms_url": { "type": "string", "format": "uri" },
        "privacy_url": { "type": "string", "format": "uri" },
        "support_url": { "type": "string", "format": "uri" }
      },
      "additionalProperties": true
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "version", "name", "description", "status", "interfaces", "input_schema", "output_schema", "auth", "pricing"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)+$" },
          "version": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "status": { "enum": ["experimental", "beta", "stable", "deprecated", "sunset"] },
          "interfaces": { "type": "object", "minProperties": 1 },
          "input_schema": { "type": "string" },
          "output_schema": { "type": "string" },
          "auth": {
            "type": "object",
            "required": ["methods"],
            "properties": {
              "methods": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["type"],
                  "properties": {
                    "type": { "enum": ["public", "session", "api_key", "oauth2", "signed_service", "x402"] },
                    "issuers": { "type": "array", "items": { "type": "string" } },
                    "scopes": { "type": "array", "items": { "type": "string" } },
                    "networks": { "type": "array", "items": { "type": "string" } }
                  },
                  "additionalProperties": true
                }
              }
            },
            "additionalProperties": true
          },
          "pricing": {
            "type": "object",
            "required": ["model"],
            "properties": {
              "model": { "enum": ["free", "per_request", "metered", "tiered", "subscription", "credits", "contract", "revenue_share", "hybrid"] },
              "amount": { "type": "string" },
              "currency": { "type": "string" },
              "unit": { "type": "string" },
              "settlement": { "type": "object" }
            },
            "additionalProperties": true
          },
          "rate_limits": { "type": "object" },
          "sla": { "type": "object" },
          "data": { "type": "object" },
          "idempotency": { "type": "object" },
          "async": { "type": "object" },
          "errors": { "type": "array" },
          "events": { "type": "array" },
          "deprecation": { "type": "object" }
        },
        "additionalProperties": true
      }
    },
    "discovery": { "type": "object" },
    "governance": { "type": "object" }
  }
}
